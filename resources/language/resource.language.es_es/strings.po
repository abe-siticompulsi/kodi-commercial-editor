# Kodi Media Center language file
# Addon Name: Commercial Editor
# Addon id: service.commercial-editor
# Addon Provider: abe-siticompulsi
msgid ""
msgstr ""
"Project-Id-Version: service.commercial-editor\n"
"Report-Msgid-Bugs-To: https://github.com/abe-siticompulsi/kodi-commercial-editor\n"
"Language: es_ES\n"
"MIME-Version: 1.0\n"
"Content-Type: text/plain; charset=UTF-8\n"
"Content-Transfer-Encoding: 8bit\n"

msgctxt "#32001"
msgid "Commercial starts here"
msgstr "La publicidad empieza aquí"

msgctxt "#32002"
msgid "Commercial ends here"
msgstr "La publicidad termina aquí"

msgctxt "#32003"
msgid "Undo"
msgstr "Deshacer"

msgctxt "#32004"
msgid "Close"
msgstr "Cerrar"

msgctxt "#32005"
msgid "Commercial saved — it will be auto-skipped on the next playback"
msgstr "Publicidad guardada — se saltará automáticamente en la próxima reproducción"

msgctxt "#32006"
msgid "Start marked at %s — press again where the commercial ends"
msgstr "Inicio marcado en %s — pulsa de nuevo donde termina la publicidad"

msgctxt "#32007"
msgid "Pending start mark cancelled"
msgstr "Marca de inicio pendiente cancelada"

msgctxt "#32008"
msgid "Removed last commercial (%s → %s) from the EDL"
msgstr "Última publicidad (%s → %s) eliminada del EDL"

msgctxt "#32009"
msgid "Nothing to undo"
msgstr "Nada que deshacer"

msgctxt "#32010"
msgid "No video is playing"
msgstr "No se está reproduciendo ningún vídeo"

msgctxt "#32011"
msgid "This video is not played from a direct file path (it is a stream), so an EDL sidecar cannot work. Enable direct file access (e.g. Direct Paths) and try again."
msgstr "Este vídeo no proviene de una ruta de archivo directa (es un stream), por lo que un archivo EDL no puede funcionar. Activa el acceso directo a los archivos (p. ej. Direct Paths) e inténtalo de nuevo."

msgctxt "#32012"
msgid "The media folder is not writable by Kodi, so the .edl sidecar cannot be saved. Make the media source writable and try again."
msgstr "Kodi no puede escribir en la carpeta del vídeo, por lo que el archivo .edl no se puede guardar. Haz que la fuente multimedia sea escribible e inténtalo de nuevo."

msgctxt "#32013"
msgid "Mark the commercial while it plays — the segment is skipped automatically next time"
msgstr "Marca la publicidad mientras se emite — el segmento se saltará automáticamente la próxima vez"

msgctxt "#32014"
msgid "Segment too short — still waiting for the end mark"
msgstr "Segmento demasiado corto — esperando la marca de fin"

msgctxt "#32020"
msgid "Verbose logging"
msgstr "Registro detallado"

msgctxt "#32021"
msgid "Open the editor when playback is paused"
msgstr "Abrir el editor cuando la reproducción esté en pausa"

msgctxt "#32022"
msgid "Bind the 'e' key to open the editor (fullscreen video)"
msgstr "Asociar la tecla 'e' para abrir el editor (vídeo a pantalla completa)"

msgctxt "#32030"
msgid "Commercial ahead — skip?"
msgstr "Publicidad a la vista — ¿saltar?"

msgctxt "#32031"
msgid "Skip"
msgstr "Saltar"

msgctxt "#32032"
msgid "Keep"
msgstr "Guardar"

msgctxt "#32033"
msgid "Go back"
msgstr "Volver atrás"

msgctxt "#32034"
msgid "Skipped %s of commercials — keep it for next time?"
msgstr "Publicidad saltada (%s) — ¿guardar para la próxima vez?"
