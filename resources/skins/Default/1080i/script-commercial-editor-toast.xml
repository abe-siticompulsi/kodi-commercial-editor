<?xml version="1.0" encoding="UTF-8"?>
<!-- SPDX-License-Identifier: GPL-3.0-or-later
     Two-button toast (both beats): message + primary/secondary buttons.
     Bottom-right, smaller and less intrusive than the marking overlay. -->
<window type="dialog">
  <defaultcontrol always="true">101</defaultcontrol>
  <zorder>99</zorder>
  <controls>
    <control type="group">
      <left>1090</left>
      <top>880</top>
      <width>780</width>
      <height>140</height>
      <control type="image">
        <left>0</left>
        <top>0</top>
        <width>780</width>
        <height>140</height>
        <texture colordiffuse="E6101820">colors/white.png</texture>
      </control>
      <control type="label" id="200">
        <left>20</left>
        <top>10</top>
        <width>740</width>
        <height>34</height>
        <font>font12</font>
        <textcolor>FFDDDDDD</textcolor>
        <align>center</align>
        <scroll>true</scroll>
        <label/>
      </control>
      <control type="grouplist" id="9000">
        <left>20</left>
        <top>54</top>
        <width>740</width>
        <height>70</height>
        <orientation>horizontal</orientation>
        <itemgap>14</itemgap>
        <align>center</align>
        <control type="button" id="101">
          <width>300</width>
          <height>62</height>
          <font>font14</font>
          <textcolor>FFFFFFFF</textcolor>
          <focusedcolor>FFFFFFFF</focusedcolor>
          <align>center</align>
          <aligny>center</aligny>
          <texturenofocus colordiffuse="FF3A4A5A" border="4">colors/white.png</texturenofocus>
          <texturefocus colordiffuse="FFE0453A" border="4">colors/white.png</texturefocus>
          <label/>
        </control>
        <control type="button" id="102">
          <width>300</width>
          <height>62</height>
          <font>font14</font>
          <textcolor>FFFFFFFF</textcolor>
          <focusedcolor>FFFFFFFF</focusedcolor>
          <align>center</align>
          <aligny>center</aligny>
          <texturenofocus colordiffuse="FF3A4A5A" border="4">colors/white.png</texturenofocus>
          <texturefocus colordiffuse="FF5A6A7A" border="4">colors/white.png</texturefocus>
          <label/>
        </control>
      </control>
    </control>
  </controls>
</window>
